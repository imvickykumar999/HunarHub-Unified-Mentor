[Unit]
Description=HunarHub Digital Marketplace Service
After=network.target mongodb.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/HunarHub/backend
ExecStart=/usr/bin/node index.js
Restart=on-failure
Environment=PORT=5000
Environment=MONGO_URI=mongodb://localhost:27017/hunarhub
Environment=JWT_SECRET=hunarhub_secret_key

[Install]
WantedBy=multi-user.target
